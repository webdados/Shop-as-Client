{
	"name": "woocommerce-shop-as-client",
	"version": "0.1.0",
	"author": "PT Woo Plugins (by Webdados)",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start",
		"translate": "npm run translate:pot && npm run translate:update",
		"translate:pot": "wp i18n make-pot . languages/shop-as-client.pot --exclude=src",
		"translate:update": "wp i18n update-po languages/shop-as-client.pot languages/*.po",
		"translate:compile": "npm run translate:mo && npm run translate:js",
		"translate:js": "wp i18n make-json languages --no-purge",
		"translate:mo": "wp i18n make-mo languages languages"
	},
	"devDependencies": {
		"@woocommerce/dependency-extraction-webpack-plugin": "^2.3.0",
		"@woocommerce/eslint-plugin": "^2.2.0",
		"@wordpress/prettier-config": "^3.5.0",
		"@wordpress/scripts": "^26.19.0",
		"classnames": "^2.5.1"
	},
	"dependencies": {
		"@wordpress/icons": "^9.42.0"
	}
}
